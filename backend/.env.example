# PromptReel AI — Backend Environment Variables
# Copy to .env and fill in your values. At least ONE AI key is required.

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=PromptReel AI
DEBUG=false
ENVIRONMENT=production

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/promptreel

# ── Security ──────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=your-super-secret-key-here

# ══════════════════════════════════════════════════════════════════════════════
# AI PROVIDER KEYS — Plan Routing
# ══════════════════════════════════════════════════════════════════════════════
#
# STUDIO plan  uses: GPT-4o → Claude 3.5 Sonnet → Grok-2 → Gemini Pro
# CREATOR plan uses: GPT-4o-mini → Grok-2 → Gemini Pro → Mistral → DeepSeek
# FREE plan    uses: Gemini Flash → Groq Llama → DeepSeek → Together → OpenRouter
#
# Only keys you provide are used. Missing keys are skipped automatically.
# Minimum recommendation for production: GEMINI_API_KEY + GROQ_API_KEY (both free tiers)

# ── Tier A — Premium (Studio plan) ───────────────────────────────────────────
# OpenAI GPT-4o → https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic Claude 3.5 Sonnet → https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Tier B — Mid (Creator plan) ──────────────────────────────────────────────
# Google Gemini 1.5 Pro → https://makersuite.google.com/app/apikey (has FREE tier)
GEMINI_API_KEY=AIza...

# xAI Grok-2 → https://console.x.ai/
GROK_API_KEY=xai-...

# Mistral Large → https://console.mistral.ai/
MISTRAL_API_KEY=...

# ── Tier C — Standard/Free (cheapest + fallback) ─────────────────────────────
# DeepSeek-V3 → https://platform.deepseek.com/ (very affordable, ~$0.001/1K tokens)
DEEPSEEK_API_KEY=sk-...

# Groq Llama 3.3 70B → https://console.groq.com/ (FREE tier, extremely fast)
GROQ_API_KEY=gsk_...

# Together AI Qwen 2.5 72B → https://api.together.xyz/ (pay-as-you-go, cheap)
TOGETHER_API_KEY=...

# OpenRouter → https://openrouter.ai/ (free Llama 3.3 70B, many models)
OPENROUTER_API_KEY=sk-or-...

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","https://your-app-domain.com"]
FRONTEND_URL=https://app.promptreel.ai

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Create a free account at https://resend.com — free up to 3000 emails/month
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@promptreel.ai

# ── Flutterwave Payments ───────────────────────────────────────────────────────
# Dashboard → https://dashboard.flutterwave.com → Settings → API Keys
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_LIVE-...
FLUTTERWAVE_SECRET_KEY=FLWSECK_LIVE-...
FLUTTERWAVE_ENCRYPT_KEY=FLWENCRYPT-...
# Dashboard → Settings → Webhooks → set hash secret
FLUTTERWAVE_WEBHOOK_HASH=your-webhook-secret-hash

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","https://app.promptreel.ai","https://chastechgroup.github.io"]
FRONTEND_URL=https://app.promptreel.ai
