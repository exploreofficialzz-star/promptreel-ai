<?xml version="1.0" encoding="utf-8"?>
<network-security-config>

    <!-- ── Production HTTPS domains (Flutterwave + PromptReel) ───────────── -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">checkout.flutterwave.com</domain>
        <domain includeSubdomains="true">api.flutterwave.com</domain>
        <domain includeSubdomains="true">flutterwave.com</domain>
        <domain includeSubdomains="true">promptreel.ai</domain>
        <domain includeSubdomains="true">promptreel-ai.onrender.com</domain>
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </domain-config>

    <!-- ── Local development (emulator + LAN) ────────────────────────────── -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">192.168.0.0</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>

    <!-- ── Base config — all other traffic uses HTTPS ────────────────────── -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </base-config>

</network-security-config>
