# Security headers for GitHub Pages (Cloudflare Pages compatible syntax)

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com; font-src https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://promptreel-ai.onrender.com;

# Serve .well-known files as JSON (required for Android App Links + iOS Universal Links)
/.well-known/assetlinks.json
  Content-Type: application/json
  Access-Control-Allow-Origin: *

/.well-known/apple-app-site-association
  Content-Type: application/json
  Access-Control-Allow-Origin: *

# Allow service worker scope at root
/flutter_service_worker.js
  Cache-Control: no-cache

# Long-cache for Flutter web build assets
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/icons/*
  Cache-Control: public, max-age=31536000, immutable
